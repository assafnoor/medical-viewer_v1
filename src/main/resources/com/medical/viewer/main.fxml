<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.medical.viewer.controller.MainController"
            styleClass="root-pane">

    <fx:define>
        <ToggleGroup fx:id="filterGroup" />
        <ToggleGroup fx:id="threshModeGroup" />
    </fx:define>

    <!-- ══ TOP TOOLBAR ═════════════════════════════════════════════════════ -->
    <top>
        <VBox styleClass="top-bar">
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="toolbar">
                <Label text="🧠 Medical DICOM Viewer" styleClass="app-title"/>
                <Separator orientation="VERTICAL"/>
                <Button fx:id="btnLoadFolder" text="📁 Load Folder"
                        styleClass="btn-primary" onAction="#onLoadFolder"/>
                <Button fx:id="btnLoadFiles"  text="📄 Load Files"
                        styleClass="btn-primary" onAction="#onLoadFiles"/>
                <Separator orientation="VERTICAL"/>
                <Label text="Threshold:" styleClass="label-sm"/>
                <Slider fx:id="sliderThreshold" min="0" max="255" value="128"
                        prefWidth="110" showTickLabels="true" blockIncrement="10"/>
                <Label fx:id="labelThreshold" text="128" styleClass="label-sm" minWidth="35"/>
                <CheckBox fx:id="checkMIP" text="MIP" selected="true"
                          onAction="#onRenderModeChanged"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="🔄 Render 3D" styleClass="btn-accent"  onAction="#onRender3D"/>
                <Button text="⬆ Export"     styleClass="btn-secondary" onAction="#onExport"/>
            </HBox>
            <HBox styleClass="status-bar" spacing="10">
                <Label fx:id="labelStatus" text="Ready — load a DICOM folder to begin"
                       styleClass="status-text"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Label fx:id="labelMeta" text="" styleClass="meta-text"/>
            </HBox>
        </VBox>
    </top>

    <!-- ══ CENTER ══════════════════════════════════════════════════════════ -->
    <center>
        <SplitPane dividerPositions="0.20, 0.78" styleClass="main-split">

            <!-- LEFT: slice list -->
            <VBox styleClass="panel-left" minWidth="170">
                <Label text="SLICES" styleClass="panel-title"/>
                <ListView fx:id="listSlices" VBox.vgrow="ALWAYS" styleClass="slice-list"
                          onMouseClicked="#onSliceSelected"/>
            </VBox>

            <!-- CENTER: canvases + controls -->
            <SplitPane orientation="VERTICAL" dividerPositions="0.72">

                <!-- 4 canvases -->
                <GridPane styleClass="view-grid" hgap="4" vgap="4">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints percentHeight="50" vgrow="ALWAYS"/>
                        <RowConstraints percentHeight="50" vgrow="ALWAYS"/>
                    </rowConstraints>

                    <VBox styleClass="canvas-container" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="AXIAL (Current Slice)" styleClass="view-label"/>
                        <Canvas fx:id="canvasAxial" width="400" height="400" VBox.vgrow="ALWAYS"/>
                    </VBox>
                    <VBox styleClass="canvas-container canvas-3d" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="3D RECONSTRUCTION" styleClass="view-label view-label-3d"/>
                        <Canvas fx:id="canvas3D" width="400" height="400" VBox.vgrow="ALWAYS"
                                onMouseDragged="#on3DDrag" onMousePressed="#on3DPress"/>
                    </VBox>
                    <VBox styleClass="canvas-container" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="CORONAL (Y)" styleClass="view-label"/>
                        <Canvas fx:id="canvasCoronal" width="400" height="200" VBox.vgrow="ALWAYS"/>
                    </VBox>
                    <VBox styleClass="canvas-container" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label text="SAGITTAL (X)" styleClass="view-label"/>
                        <Canvas fx:id="canvasSagittal" width="400" height="200" VBox.vgrow="ALWAYS"/>
                    </VBox>
                </GridPane>

                <!-- BOTTOM: processing controls -->
                <ScrollPane fitToWidth="true" styleClass="controls-scroll">
                    <VBox styleClass="controls-panel" spacing="10">
                        <Label text="IMAGE PROCESSING" styleClass="panel-title"/>

                        <!-- Brightness / Contrast / Gamma -->
                        <GridPane hgap="10" vgap="6">
                            <columnConstraints>
                                <ColumnConstraints minWidth="110" maxWidth="130"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                                <ColumnConstraints minWidth="50"/>
                            </columnConstraints>
                            <Label text="Brightness" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="ctrl-label"/>
                            <Slider fx:id="sliderBrightness" min="-200" max="200" value="0"
                                    GridPane.columnIndex="1" GridPane.rowIndex="0"
                                    onMouseReleased="#onImageParamChanged" onKeyReleased="#onImageParamChanged"/>
                            <Label fx:id="lblBrightness" text="0" GridPane.columnIndex="2" GridPane.rowIndex="0" styleClass="ctrl-value"/>

                            <Label text="Contrast" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="ctrl-label"/>
                            <Slider fx:id="sliderContrast" min="0.1" max="4.0" value="1.0"
                                    GridPane.columnIndex="1" GridPane.rowIndex="1"
                                    onMouseReleased="#onImageParamChanged" onKeyReleased="#onImageParamChanged"/>
                            <Label fx:id="lblContrast" text="1.0" GridPane.columnIndex="2" GridPane.rowIndex="1" styleClass="ctrl-value"/>

                            <Label text="Gamma" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="ctrl-label"/>
                            <Slider fx:id="sliderGamma" min="0.1" max="3.0" value="1.0"
                                    GridPane.columnIndex="2" GridPane.rowIndex="2"
                                    onMouseReleased="#onImageParamChanged" onKeyReleased="#onImageParamChanged"/>
                            <Label fx:id="lblGamma" text="1.0" GridPane.columnIndex="2" GridPane.rowIndex="2" styleClass="ctrl-value"/>
                        </GridPane>

                        <Separator/>

                        <!-- Standard filters -->
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Filters:" styleClass="ctrl-label"/>
                            
                            <ToggleButton fx:id="btnFilterNone"    text="None"           selected="true" toggleGroup="$filterGroup" onAction="#onFilterChanged"/>
                            <ToggleButton fx:id="btnFilterBlur"    text="Blur"            toggleGroup="$filterGroup" onAction="#onFilterChanged"/>
                            <ToggleButton fx:id="btnFilterSharpen" text="Sharpen"         toggleGroup="$filterGroup" onAction="#onFilterChanged"/>
                            <ToggleButton fx:id="btnFilterEdge"    text="Edges (Lap)"     toggleGroup="$filterGroup" onAction="#onFilterChanged"/>
                            <ToggleButton fx:id="btnFilterSobel"   text="Edges (Sobel)"   toggleGroup="$filterGroup" onAction="#onFilterChanged"/>
                            <ToggleButton fx:id="btnFilterHistEq"  text="Hist. Equalize"  toggleGroup="$filterGroup" onAction="#onFilterChanged"/>
                            <ToggleButton fx:id="btnFilterInvert"  text="Invert"          toggleGroup="$filterGroup" onAction="#onFilterChanged"/>
                        </HBox>

                        <!-- ══════════════════════════════════════════════════════════
                             ✅  THRESHOLD FILTER SECTION
                             ══════════════════════════════════════════════════════════ -->
                        <VBox styleClass="thresh-panel" spacing="8">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="⬛ THRESHOLD FILTER" styleClass="thresh-title"/>
                            </HBox>

                            <!-- Mode selector row -->
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Mode:" styleClass="ctrl-label"/>
                                
                                <ToggleButton fx:id="btnThreshOff"      text="Off"         selected="true"
                                              toggleGroup="$threshModeGroup" onAction="#onThreshModeChanged"/>
                                <ToggleButton fx:id="btnThreshBinary"   text="Binary"
                                              toggleGroup="$threshModeGroup" onAction="#onThreshModeChanged"/>
                                <ToggleButton fx:id="btnThreshInverted" text="Inverted"
                                              toggleGroup="$threshModeGroup" onAction="#onThreshModeChanged"/>
                                <ToggleButton fx:id="btnThreshMulti"    text="Window"
                                              toggleGroup="$threshModeGroup" onAction="#onThreshModeChanged"/>
                                <ToggleButton fx:id="btnThreshAdaptive" text="Adaptive"
                                              toggleGroup="$threshModeGroup" onAction="#onThreshModeChanged"/>
                                <ToggleButton fx:id="btnThreshOtsu"     text="Otsu (Auto)"
                                              toggleGroup="$threshModeGroup" onAction="#onThreshModeChanged"/>
                            </HBox>

                            <!-- Controls (shown/hidden per mode) -->
                            <GridPane fx:id="gridThreshControls" hgap="10" vgap="8" styleClass="thresh-grid">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="130" maxWidth="150"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                    <ColumnConstraints minWidth="55"/>
                                </columnConstraints>

                                <!-- Threshold value (Binary / Inverted) -->
                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="2">
                                    <Label text="Threshold (T)" styleClass="ctrl-label"/>
                                    <Label text="binary / inverted" styleClass="ctrl-hint"/>
                                </VBox>
                                <Slider fx:id="sliderThreshVal" min="0" max="255" value="128"
                                        GridPane.columnIndex="1" GridPane.rowIndex="0"
                                        showTickLabels="true" blockIncrement="5"
                                        onMouseReleased="#onThreshParamChanged"
                                        onKeyReleased="#onThreshParamChanged"/>
                                <Label fx:id="lblThreshVal" text="128"
                                       GridPane.columnIndex="2" GridPane.rowIndex="0"
                                       styleClass="ctrl-value thresh-value"/>

                                <!-- Window Lo (Multi-level) -->
                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="2">
                                    <Label text="Window Lo" styleClass="ctrl-label"/>
                                    <Label text="window / adaptive bias" styleClass="ctrl-hint"/>
                                </VBox>
                                <Slider fx:id="sliderThreshLo" min="0" max="255" value="60"
                                        GridPane.columnIndex="1" GridPane.rowIndex="1"
                                        showTickLabels="true" blockIncrement="5"
                                        onMouseReleased="#onThreshParamChanged"
                                        onKeyReleased="#onThreshParamChanged"/>
                                <Label fx:id="lblThreshLo" text="60"
                                       GridPane.columnIndex="2" GridPane.rowIndex="1"
                                       styleClass="ctrl-value thresh-value"/>

                                <!-- Window Hi (Multi-level) -->
                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="2" spacing="2">
                                    <Label text="Window Hi" styleClass="ctrl-label"/>
                                    <Label text="multi-level upper bound" styleClass="ctrl-hint"/>
                                </VBox>
                                <Slider fx:id="sliderThreshHi" min="0" max="255" value="200"
                                        GridPane.columnIndex="1" GridPane.rowIndex="2"
                                        showTickLabels="true" blockIncrement="5"
                                        onMouseReleased="#onThreshParamChanged"
                                        onKeyReleased="#onThreshParamChanged"/>
                                <Label fx:id="lblThreshHi" text="200"
                                       GridPane.columnIndex="2" GridPane.rowIndex="2"
                                       styleClass="ctrl-value thresh-value"/>

                                <!-- Adaptive block size -->
                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="3" spacing="2">
                                    <Label text="Block Size" styleClass="ctrl-label"/>
                                    <Label text="adaptive neighbourhood" styleClass="ctrl-hint"/>
                                </VBox>
                                <Slider fx:id="sliderThreshBlock" min="3" max="99" value="31"
                                        GridPane.columnIndex="1" GridPane.rowIndex="3"
                                        majorTickUnit="24" showTickLabels="true" snapToTicks="false"
                                        onMouseReleased="#onThreshParamChanged"
                                        onKeyReleased="#onThreshParamChanged"/>
                                <Label fx:id="lblThreshBlock" text="31"
                                       GridPane.columnIndex="2" GridPane.rowIndex="3"
                                       styleClass="ctrl-value thresh-value"/>
                            </GridPane>

                            <!-- Otsu info bar -->
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="Otsu T =" styleClass="ctrl-hint"/>
                                <Label fx:id="lblOtsuT" text="—" styleClass="thresh-otsu-val"/>
                                <Label text="(computed automatically)" styleClass="ctrl-hint"/>
                            </HBox>
                        </VBox>

                        <!-- ══════════════════════════════════════════════════════════
                             ✅  BAND PASS FILTER SECTION
                             ══════════════════════════════════════════════════════════ -->
                        <VBox styleClass="bpf-panel" spacing="8">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="🔁 BAND PASS FILTER (FFT)" styleClass="bpf-title"/>
                                <ToggleButton fx:id="btnFilterBandPass"
                                              text="Enable Band Pass"
                                              styleClass="btn-bandpass"
                                              toggleGroup="$filterGroup"
                                              onAction="#onFilterChanged"/>
                                <Button text="📊 Show Spectrum"
                                        styleClass="btn-spectrum"
                                        onAction="#onShowSpectrum"/>
                            </HBox>

                            <GridPane hgap="10" vgap="8" styleClass="bpf-grid">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="130" maxWidth="150"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                    <ColumnConstraints minWidth="55"/>
                                </columnConstraints>

                                <!-- Low cutoff -->
                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="2">
                                    <Label text="Low Cutoff (D_lo)" styleClass="ctrl-label"/>
                                    <Label text="suppresses DC &amp; fog" styleClass="ctrl-hint"/>
                                </VBox>
                                <Slider fx:id="sliderBPFLow" min="0" max="255" value="10"
                                        GridPane.columnIndex="1" GridPane.rowIndex="0"
                                        showTickLabels="true" blockIncrement="5"
                                        onMouseReleased="#onBPFChanged" onKeyReleased="#onBPFChanged"/>
                                <Label fx:id="lblBPFLow" text="10"
                                       GridPane.columnIndex="2" GridPane.rowIndex="0"
                                       styleClass="ctrl-value bpf-value"/>

                                <!-- High cutoff -->
                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="2">
                                    <Label text="High Cutoff (D_hi)" styleClass="ctrl-label"/>
                                    <Label text="removes noise &amp; fine grain" styleClass="ctrl-hint"/>
                                </VBox>
                                <Slider fx:id="sliderBPFHigh" min="0" max="255" value="120"
                                        GridPane.columnIndex="1" GridPane.rowIndex="1"
                                        showTickLabels="true" blockIncrement="5"
                                        onMouseReleased="#onBPFChanged" onKeyReleased="#onBPFChanged"/>
                                <Label fx:id="lblBPFHigh" text="120"
                                       GridPane.columnIndex="2" GridPane.rowIndex="1"
                                       styleClass="ctrl-value bpf-value"/>

                                <!-- Butterworth order -->
                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="2" spacing="2">
                                    <Label text="Filter Order (n)" styleClass="ctrl-label"/>
                                    <Label text="1=soft roll-off, 5=sharp" styleClass="ctrl-hint"/>
                                </VBox>
                                <Slider fx:id="sliderBPFOrder" min="1" max="5" value="2"
                                        GridPane.columnIndex="1" GridPane.rowIndex="2"
                                        majorTickUnit="1" minorTickCount="0"
                                        showTickLabels="true" snapToTicks="true"
                                        onMouseReleased="#onBPFChanged" onKeyReleased="#onBPFChanged"/>
                                <Label fx:id="lblBPFOrder" text="2"
                                       GridPane.columnIndex="2" GridPane.rowIndex="2"
                                       styleClass="ctrl-value bpf-value"/>
                            </GridPane>

                            <!-- Visual bandwidth diagram -->
                            <HBox alignment="CENTER" spacing="4">
                                <Label text="← suppress" styleClass="bpf-hint-lo"/>
                                <Label fx:id="lblBPFBand" text="▓▓▓ pass band ▓▓▓"
                                       styleClass="bpf-band-label"/>
                                <Label text="suppress →" styleClass="bpf-hint-hi"/>
                            </HBox>
                        </VBox>

                        <Separator/>

                        <!-- Morphological operations -->
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Morphology:" styleClass="ctrl-label"/>
                            <Label text="Radius:" styleClass="ctrl-label"/>
                            <Spinner fx:id="spinnerMorphRadius" min="1" max="10" initialValue="2"
                                     editable="true" prefWidth="65"/>
                            <Button text="Erode"    onAction="#onErode"        styleClass="btn-morph"/>
                            <Button text="Dilate"   onAction="#onDilate"       styleClass="btn-morph"/>
                            <Button text="Open"     onAction="#onMorphOpen"    styleClass="btn-morph"/>
                            <Button text="Close"    onAction="#onMorphClose"   styleClass="btn-morph"/>
                            <Button text="Gradient" onAction="#onMorphGradient" styleClass="btn-morph"/>
                            <Button text="↺ Reset"  onAction="#onResetImage"   styleClass="btn-reset"/>
                        </HBox>
                    </VBox>
                </ScrollPane>
            </SplitPane>

            <!-- RIGHT: metadata + navigation -->
            <VBox styleClass="panel-right" minWidth="210" maxWidth="270">
                <Label text="METADATA" styleClass="panel-title"/>
                <TextArea fx:id="textMeta" editable="false" wrapText="true"
                          VBox.vgrow="ALWAYS" styleClass="meta-area"/>
                <Separator/>
                <Label text="NAVIGATION" styleClass="panel-title"/>
                <HBox alignment="CENTER" spacing="6">
                    <Button text="◀◀" onAction="#onFirstSlice" styleClass="nav-btn"/>
                    <Button text="◀"  onAction="#onPrevSlice"  styleClass="nav-btn"/>
                    <Label fx:id="labelSliceNum" text="0 / 0"  styleClass="slice-num"/>
                    <Button text="▶"  onAction="#onNextSlice"  styleClass="nav-btn"/>
                    <Button text="▶▶" onAction="#onLastSlice"  styleClass="nav-btn"/>
                </HBox>
                <Slider fx:id="sliderSliceNav" min="0" max="1" value="0"
                        orientation="VERTICAL" VBox.vgrow="ALWAYS" prefHeight="180"
                        onMouseDragged="#onSliceNavChanged" onMouseClicked="#onSliceNavChanged"/>
                <ProgressBar fx:id="progressLoad" prefWidth="190" visible="false" progress="0"/>
                <Label fx:id="labelProgress" text="" styleClass="label-sm"/>
            </VBox>

        </SplitPane>
    </center>
</BorderPane>
